# Position
anchor=top-right
margin=30,0,0,0

# Sizing
width=350
height=150
padding=15
border-size=3
border-radius=0,15

# Styling
background-color=#0d0e1fbb
font=0xProto Monospace

# Behaviour
default-timeout=5000
# default-timeout=0
ignore-timeout=0
# sort=time
layer=overlay
max-visible=5
max-icon-size=48

# Urgency styling
[urgency=low]
border-color=#8fbf9f
text-color=#8fbf9f
# default-timeout=0

[urgency=normal]
border-color=#f3bc70
text-color=#f3bc70
layer=overlay
# default-timeout=0

[urgency=critical]
border-color=#e67e80
background-color=#3a1f28bb
text-color=#e67e80
default-timeout=0
